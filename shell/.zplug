# Plugins (no manager — direct source)
# Homebrew-installed
source $HOMEBREW_PREFIX/share/powerlevel10k/powerlevel10k.zsh-theme
source $HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOMEBREW_PREFIX/opt/zsh-fast-syntax-highlighting/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

# Git-cloned (~/.zsh/plugins/)
source ~/.zsh/plugins/alias-tips/alias-tips.plugin.zsh
source ~/.zsh/plugins/zsh-autocomplete/zsh-autocomplete.plugin.zsh

# Cached completions — generate on first use, source thereafter
mkdir -p ~/.zsh/cache
[[ $commands[kubectl] && ! -s ~/.zsh/cache/kubectl.zsh ]] && kubectl completion zsh >| ~/.zsh/cache/kubectl.zsh 2>/dev/null
[[ $commands[docker]  && ! -s ~/.zsh/cache/docker.zsh  ]] && docker completion zsh  >| ~/.zsh/cache/docker.zsh  2>/dev/null
for f in ~/.zsh/cache/*.zsh(N); do source "$f"; done
(( $+commands[kubecolor] )) && compdef kubecolor=kubectl

# Only rebuild zcompdump once a day (build fresh if missing)
autoload -Uz compinit
_zcompdump=${ZDOTDIR:-$HOME}/.zcompdump
if [[ ! -f $_zcompdump ]] || [[ $(date +'%j') != $(/usr/bin/stat -f '%Sm' -t '%j' $_zcompdump) ]]; then
  compinit
else
  compinit -C
fi
unset _zcompdump

# Lazy NVM
export NVM_DIR="$HOME/.nvm"
nvm() {
  unset -f nvm node npm npx
  [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
  nvm "$@"
}
node()  { unset -f nvm node npm npx; [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"; node "$@"; }
npm()   { unset -f nvm node npm npx; [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"; npm "$@"; }
npx()   { unset -f nvm node npm npx; [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"; npx "$@"; }

# Lazy pyenv
if (( $+commands[pyenv] )); then
  pyenv() {
    unset -f pyenv
    eval "$(command pyenv init -)"
    pyenv "$@"
  }
fi
