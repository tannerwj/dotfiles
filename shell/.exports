# Locale
export LANG="en_US"
export LC_ALL="en_US.UTF-8"

# Editor
export EDITOR="vim"

# History
export HISTSIZE=32768
export HISTFILESIZE=$HISTSIZE
export HISTCONTROL="ignoredups:ignorespace"
export HISTTIMEFORMAT="%Y-%m-%d %H:%M:%S "
export HISTIGNORE="bg:clear:exit:fg:history:cd -:pwd:exit:date:* --help"

# PATH (uv tool shims + personal scripts, prepended after brew shellenv)
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# Node TLS: trust system CAs for npm/claude/etc.
export NODE_EXTRA_CA_CERTS="$HOME/.claude/system-ca-certs.pem"

# Tools
export EXA_COLORS='uu=1;36:gu=1;36'
export DOTFILES="git@github.com:CraightonH/dotfiles.git"
export PIP_INDEX_URL=https://nexus.taxhawk.com/repository/pypi/simple/
export SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt

# Infrastructure
export VAULT_ADDR=https://hcp-virginia-1.private.vault.49af6eb6-c70e-4f73-8e37-7b3204522d55.aws.hashicorp.cloud:8200
export ANSIBLE_CONFIG=~/git/ansible/ansible.cfg
export ANSIBLE_INSTALL_DIR="${ANSIBLE_CONFIG%/*}"
export GITLAB_URL=https://git.taxhawk.com

# macOS
if [[ "$OSTYPE" == "darwin"* ]]; then
  export HOMEBREW_AUTO_UPDATE_SECS=604800
  export HOMEBREW_FORBIDDEN_CASKS="microsoft-auto-update"
  export VAULT_NAMESPACE="admin"
  export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

  # Python CA bundle (system + homebrew CAs; regenerated by install.sh)
  # Lives outside ~/Desktop because macOS TCC blocks subprocess reads there
  export SSL_CERT_FILE=~/.config/ssl/python-ca-bundle.pem
  export REQUESTS_CA_BUNDLE=~/.config/ssl/python-ca-bundle.pem


  export MYSQL_PS1="\u@\h \d > "
fi
